# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
# Dependencies
node_modules/

# Build output
.next/
out/
build/

# Environment - never commit real values
.env
.env.local
.env.production

# SQLite database files - data stays on server, not in git
*.db
*.db-journal
*.db-shm
*.db-wal

# Prisma generated
node_modules/.prisma/
